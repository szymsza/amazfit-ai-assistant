{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "node",
    "target": "es6",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "rootDir": "./src",
    "outDir": ".",
    "noEmit": false,
    "typeRoots": []
  },
  "include": [
    "src/global.d.ts",
    "src/app.ts",
    "src/page/**/*.ts",
    "src/app-side/**/*.ts",
    "src/setting/**/*.ts",
    "src/utils/**/*.ts"
  ],
  "exclude": ["node_modules", "**/node_modules/*", "../node_modules"]
}
